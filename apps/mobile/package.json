{
  "name": "@wise-finance/mobile",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "dev": "dotenv -e ../../.env.local -- expo start",
    "start": "dotenv -e ../../.env.local -- expo start",
    "start:lan": "dotenv -e ../../.env.local -- expo start --lan",
    "start:tunnel": "dotenv -e ../../.env.local -- expo start --tunnel",
    "android": "dotenv -e ../../.env.local -- expo start --android",
    "ios": "dotenv -e ../../.env.local -- expo start --ios",
    "web": "dotenv -e ../../.env.local -- expo start --web",
    "web:clear": "dotenv -e ../../.env.local -- expo start --web --clear",
    "test": "jest --runInBand",
    "test:watch": "jest --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@clerk/clerk-expo": "^2.19.31",
    "@expo/vector-icons": "^15.0.3",
    "@tanstack/react-form": "^1.29.1",
    "convex": "^1.37.0",
    "expo": "^54.0.23",
    "expo-secure-store": "^55.0.13",
    "expo-status-bar": "~3.0.8",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-native": "0.81.5",
    "react-native-paper": "^5.14.5",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-web": "^0.21.0",
    "zod": "^4.4.2"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.10",
    "babel-preset-expo": "^55.0.19",
    "jest": "^29.7.0",
    "jest-expo": "^55.0.16",
    "react-test-renderer": "^19.2.5"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.ts"
    ]
  }
}
